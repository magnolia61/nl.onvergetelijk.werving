<?xml version="1.0"?>
<extension key="nl.onvergetelijk.werving" type="module">
  <file>werving</file>
  <name>Onvergetelijk - Werving</name>
  <description>Werving van deelnemers en leiding voor kampseizoenen</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Richard van Oosterhout</author>
    <email>webteam@onvergetelijk.nl</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://www.onvergetelijk.nl</url>
    <url desc="Documentation">https://www.onvergetelijk.nl</url>
    <url desc="Support">https://www.onvergetelijk.nl</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-04-27</releaseDate>
  <version>3.0.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.13</ver>
  </compatibility>
  <comments>Onderdeel van de Onvergetelijk-extensie-suite voor Stichting Onvergetelijke Zomerkampen. Compatibel met CiviCRM 6.13, PHP 8.4 en Smarty 5.</comments>
  <requires>
    <ext>nl.onvergetelijk.base</ext>
    <ext>nl.onvergetelijk.account</ext>
    <ext>nl.onvergetelijk.acl</ext>
    <ext>nl.onvergetelijk.cv</ext>
    <ext>nl.onvergetelijk.intake</ext>
    <ext>nl.onvergetelijk.partstatus</ext>
  </requires>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/Werving</namespace>
    <format>23.02.1</format>
    <angularModule>crmWerving</angularModule>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
  </mixins>
</extension>
